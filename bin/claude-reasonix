#!/usr/bin/env bash
set -euo pipefail

INSTALL_HOME="${CLAUDE_REASONIX_FLEET_INSTALL_HOME:-${CLAUDE_CODEX_FLEET_INSTALL_HOME:-$HOME/.claude/reasonix-fleet}}"
FLEET_HOME="${CLAUDE_REASONIX_FLEET_HOME:-${CLAUDE_CODEX_FLEET_HOME:-$INSTALL_HOME}}"
STATE_DIR="$FLEET_HOME/state"
RUNTIME_DIR="$FLEET_HOME/runtime"
ENABLED_FILE="$STATE_DIR/enabled"
WORKERS_FILE="$STATE_DIR/workers"
MCP_FILE="$RUNTIME_DIR/mcp.json"
SETTINGS_FILE="$INSTALL_HOME/bridge-settings.json"
RENDERED_SETTINGS="$RUNTIME_DIR/bridge-settings.rendered.json"
PROMPT_FILE="$INSTALL_HOME/system-prompt-reasonix.md"
MCP_SERVER_FILE="$INSTALL_HOME/reasonix-fleet-mcp.py"
GATEWAY_FILE="$INSTALL_HOME/reasonix-native-gateway.py"
CCR_PROXY_FILE="$INSTALL_HOME/ccr-claude-proxy.py"
AGENTS_FILE="$RUNTIME_DIR/agents.json"
CCR_HOME="$RUNTIME_DIR/ccr-home"
CCR_CONFIG_DIR="$CCR_HOME/.claude-code-router"
CCR_CONFIG_FILE="$CCR_CONFIG_DIR/config.json"
CCR_CUSTOM_ROUTER_FILE="$CCR_CONFIG_DIR/custom-router.js"
CCR_AGENTS_FILE="$RUNTIME_DIR/ccr-agents.json"

CLAUDE_BIN="${CLAUDE_BIN:-claude}"
CODEX_BIN="${CODEX_BIN:-codex}"
CCR_BIN="${CCR_BIN:-ccr}"
DEFAULT_WORKERS="${CLAUDE_REASONIX_FLEET_DEFAULT_WORKERS:-${CLAUDE_CODEX_FLEET_DEFAULT_WORKERS:-16}}"
NATIVE_GATEWAY_PID=""
NATIVE_GATEWAY_URL=""
CCR_SERVICE_PID=""
CCR_PROXY_PID=""
CCR_PROXY_URL=""
ROUTER_SESSION_RUNTIME_DIR=""
ROUTER_PREPARED=0

# The reasonix flavor is the only flavor. All invocation names run reasonix.
# Export both names: hooks/gateway read CLAUDE_REASONIX_FLAVOR first, CLAUDE_CODEX_
# FLAVOR as the back-compat fallback for an in-flight session.
CLAUDE_REASONIX_FLAVOR="reasonix"
CLAUDE_CODEX_FLAVOR="reasonix"
export CLAUDE_REASONIX_FLAVOR CLAUDE_CODEX_FLAVOR

if [[ "$CLAUDE_REASONIX_FLAVOR" == "reasonix" ]]; then
  : "${CLAUDE_CODEX_CCR_CODEX_MODEL:=${CLAUDE_REASONIX_CCR_CODEX_MODEL:-claude-reasonix-flash}}"
  : "${CLAUDE_CODEX_SUBAGENT_MODEL:=${CLAUDE_REASONIX_SUBAGENT_MODEL:-claude-reasonix-flash}}"
  : "${ANTHROPIC_CUSTOM_MODEL_OPTION:=claude-reasonix-flash}"
  # The worker agents (--agents) carry a <CCR-SUBAGENT-MODEL> route tag that decides
  # where each lane actually goes. Both reasonix and deepseek routes point at
  # claude-reasonix-flash (the only gateway-served model in reasonix mode).
  : "${CLAUDE_CODEX_CCR_CODEX_ROUTE:=${CLAUDE_REASONIX_CCR_CODEX_ROUTE:-codex-gateway,claude-reasonix-flash}}"
  : "${CLAUDE_CODEX_CCR_DEEPSEEK_ROUTE:=${CLAUDE_REASONIX_CCR_DEEPSEEK_ROUTE:-codex-gateway,claude-reasonix-flash}}"
  # All deepseek-* agent types also run on reasonix-flash.
  : "${CLAUDE_CODEX_CCR_DEEPSEEK_MODEL:=${CLAUDE_REASONIX_CCR_DEEPSEEK_MODEL:-claude-reasonix-flash}}"
  # UltraCode / Dynamic Workflow defaults to NATIVE mode in reasonix flavor: each
  # agent() lane keeps its reasonix-*/deepseek-* agentType (a native Claude Code
  # subagent type) which CCR routes to claude-reasonix-flash — this is what gives
  # the parallel phase fan-out (Foundation/CodeReview/Verify) instead of the
  # serial single-MCP-worker behaviour of "fleet" mode. native_subagents=1 lets
  # only-reasonix-fleet.py whitelist those native lanes through. Both are required
  # for fan-out; without them the workflow falls back to one-MCP-lane-at-a-time.
  : "${CLAUDE_CODEX_WORKFLOW_MODE:=${CLAUDE_REASONIX_WORKFLOW_MODE:-native}}"
  : "${CLAUDE_CODEX_NATIVE_SUBAGENTS:=${CLAUDE_REASONIX_NATIVE_SUBAGENTS:-1}}"
  export CLAUDE_CODEX_CCR_CODEX_MODEL CLAUDE_CODEX_SUBAGENT_MODEL ANTHROPIC_CUSTOM_MODEL_OPTION
  export CLAUDE_CODEX_CCR_CODEX_ROUTE CLAUDE_CODEX_CCR_DEEPSEEK_ROUTE CLAUDE_CODEX_CCR_DEEPSEEK_MODEL
  export CLAUDE_CODEX_WORKFLOW_MODE CLAUDE_CODEX_NATIVE_SUBAGENTS
  # The gateway is spawned with a stripped PATH that often lacks the fnm shim dir
  # holding `reasonix` AND `node` (reasonix is a Node CLI — it needs node on PATH
  # to run at all). Resolve them here, while the launcher's PATH is still complete,
  # export REASONIX_BIN (absolute) and prepend the bin dir so the child gateway can
  # actually invoke reasonix. Without this the lane fails with "Not logged in /
  # please run /login" and returns a synthetic 0-token result.
  if [[ -z "${REASONIX_BIN:-}" ]]; then
    _rx_bin="$(command -v reasonix 2>/dev/null || true)"
    if [[ -n "$_rx_bin" ]]; then
      export REASONIX_BIN="$_rx_bin"
      _rx_dir="$(dirname "$_rx_bin")"
      case ":$PATH:" in
        *":$_rx_dir:"*) ;;
        *) export PATH="$_rx_dir:$PATH" ;;
      esac
    fi
  fi
  # Session isolation for fan-out cache: stock reasonix acp names its persisted
  # session by a MINUTE-granular timestamp and RESUMES any same-name session, so
  # concurrent lanes inherit each other's history (measured: in_tok inflates
  # ~+10829 tok/lane, cache swings 60-94%). Run each acp lane with an ephemeral
  # (non-persisted) session so lanes are fully isolated. Honored by the one-line
  # reasonix dist patch (REASONIX_ACP_EPHEMERAL_SESSION). The gateway also sets
  # this on the child env; exporting here covers any direct reasonix spawn too.
  : "${REASONIX_ACP_EPHEMERAL_SESSION:=1}"
  export REASONIX_ACP_EPHEMERAL_SESSION
fi

usage() {
  cat <<'EOF'
Usage:
  claude-reasonix on [concurrency]   Enable Claude -> Reasonix fleet mode
  claude-reasonix off                Disable fleet mode
  claude-reasonix status             Show current mode and default concurrency
  claude-reasonix workers <count>    Set default Reasonix task concurrency
  claude-reasonix task <prompt>      Run one Claude task through Reasonix fleet, then auto-disable
  claude-reasonix run [claude args]  Start Claude in Reasonix Fleet mode
  claude-reasonix router [args]      Start explicit Claude Code Router native-subagent mode
  claude-reasonix router-login [args] Experimental CCR mode that tries Claude login passthrough
  claude-reasonix router-qwen [args] Start CCR mode with local Qwen3.6 as the main model
  claude-reasonix [claude args]      Same as run: always Reasonix Fleet mode
  claude-reasonix plain [args]       Start raw Claude without Reasonix Fleet
  claude-reasonix doctor             Validate local bridge files and commands

Environment overrides:
  CLAUDE_REASONIX_FLEET_DEFAULT_WORKERS=16
  CLAUDE_REASONIX_NATIVE_SUBAGENTS=0
  CLAUDE_REASONIX_NATIVE_SUBAGENTS=1 # experimental native gateway mode
  CCR_BIN=ccr
  CLAUDE_REASONIX_CCR_PORT=3456
  CLAUDE_REASONIX_ANTHROPIC_API_KEY=... # preferred for router main Anthropic provider
  CLAUDE_REASONIX_CCR_QWEN_MODEL=qwen36-mlx
  CLAUDE_REASONIX_QWEN_ANTHROPIC_BASE_URL=http://127.0.0.1:14000/v1/messages

The worker count is dynamic. This launcher starts one Reasonix Fleet MCP server,
not N static Reasonix servers. Claude can ask that server to run any number of
Reasonix tasks, with this value used only as the default concurrency.
EOF
}

ensure_dirs() {
  mkdir -p "$STATE_DIR" "$RUNTIME_DIR"
}

# bridge-settings.json is a portable template: the hook commands carry the
# __INSTALL_HOME__ placeholder so the repo holds no machine path. Render a runtime
# copy with the real INSTALL_HOME substituted and hand THAT to `claude --settings`.
render_settings() {
  ensure_dirs
  python3 - "$SETTINGS_FILE" "$INSTALL_HOME" "$RENDERED_SETTINGS" <<'PY'
import sys
src, install_home, dst = sys.argv[1:4]
with open(src, "r", encoding="utf-8") as fh:
    text = fh.read()
text = text.replace("__INSTALL_HOME__", install_home)
with open(dst, "w", encoding="utf-8") as fh:
    fh.write(text)
PY
}

prepare_router_runtime() {
  if [[ "$ROUTER_PREPARED" == "1" ]]; then
    return 0
  fi
  ensure_dirs
  ROUTER_SESSION_RUNTIME_DIR="$RUNTIME_DIR/router-sessions/$$"
  mkdir -p "$ROUTER_SESSION_RUNTIME_DIR"
  CCR_HOME="$ROUTER_SESSION_RUNTIME_DIR/ccr-home"
  CCR_CONFIG_DIR="$CCR_HOME/.claude-code-router"
  CCR_CONFIG_FILE="$CCR_CONFIG_DIR/config.json"
  CCR_CUSTOM_ROUTER_FILE="$CCR_CONFIG_DIR/custom-router.js"
  CCR_AGENTS_FILE="$ROUTER_SESSION_RUNTIME_DIR/ccr-agents.json"
  ROUTER_PREPARED=1
}

cleanup_router_runtime() {
  if [[ -n "${ROUTER_SESSION_RUNTIME_DIR:-}" && -d "$ROUTER_SESSION_RUNTIME_DIR" ]]; then
    case "${CLAUDE_REASONIX_KEEP_ROUTER_RUNTIME:-${CLAUDE_CODEX_KEEP_ROUTER_RUNTIME:-0}}" in
      1|true|TRUE|yes|YES|on|ON) ;;
      *) rm -rf "$ROUTER_SESSION_RUNTIME_DIR" ;;
    esac
  fi
  ROUTER_SESSION_RUNTIME_DIR=""
  ROUTER_PREPARED=0
}

normalize_workers() {
  local value="${1:-}"
  [[ "$value" =~ ^[0-9]+$ ]] || {
    echo "workers must be a number" >&2
    exit 2
  }
  (( value >= 1 )) || {
    echo "workers must be at least 1" >&2
    exit 2
  }
  printf '%s\n' "$value"
}

current_workers() {
  if [[ -f "$WORKERS_FILE" ]]; then
    normalize_workers "$(tr -d '[:space:]' < "$WORKERS_FILE")"
  else
    normalize_workers "$DEFAULT_WORKERS"
  fi
}

native_subagents_enabled() {
  case "${CLAUDE_REASONIX_NATIVE_SUBAGENTS:-${CLAUDE_CODEX_NATIVE_SUBAGENTS:-0}}" in
    0|false|FALSE|off|OFF|no|NO) return 1 ;;
    *) return 0 ;;
  esac
}

set_workers() {
  ensure_dirs
  normalize_workers "$1" > "$WORKERS_FILE"
}

is_enabled() {
  [[ -f "$ENABLED_FILE" ]]
}

generate_config() {
  ensure_dirs
  local workers
  workers="$(current_workers)"
  python3 - "$MCP_FILE" "$workers" "$CODEX_BIN" "$MCP_SERVER_FILE" "$RUNTIME_DIR" <<'PY'
import json
import os
import sys

path = sys.argv[1]
default_concurrency = int(sys.argv[2])
reasonix_bin = sys.argv[3]
mcp_server = sys.argv[4]
runtime_dir = sys.argv[5]

model = os.getenv("REASONIX_FLEET_MODEL", "gpt-5.4")
reasoning = os.getenv("REASONIX_FLEET_REASONING", "xhigh")
service_tier = os.getenv("REASONIX_FLEET_SERVICE_TIER", "fast")
web_search = os.getenv("REASONIX_FLEET_WEB_SEARCH", "live")
sandbox = os.getenv("REASONIX_FLEET_SANDBOX", "workspace-write")
approval = os.getenv("REASONIX_FLEET_APPROVAL", "never")

servers = {
    "reasonix_fleet": {
        "command": "/usr/bin/env",
        "args": ["python3", mcp_server],
        "env": {
            "CODEX_BIN": reasonix_bin,
            "REASONIX_FLEET_DEFAULT_CONCURRENCY": str(default_concurrency),
            "REASONIX_FLEET_MODEL": model,
            "REASONIX_FLEET_REASONING": reasoning,
            "REASONIX_FLEET_SERVICE_TIER": service_tier,
            "REASONIX_FLEET_WEB_SEARCH": web_search,
            "REASONIX_FLEET_SANDBOX": sandbox,
            "REASONIX_FLEET_APPROVAL": approval,
            "REASONIX_FLEET_LOG_DIR": os.path.join(runtime_dir, "logs"),
            # Flavor + reasonix wiring so the MCP worker runs Reasonix via acp
            # in a claude-reasonix session. REASONIX_BIN must be absolute (the MCP
            # is spawned with a stripped PATH that lacks the fnm shim dir).
            "CLAUDE_CODEX_FLAVOR": os.getenv("CLAUDE_REASONIX_FLAVOR", os.getenv("CLAUDE_CODEX_FLAVOR", "reasonix")),
            "REASONIX_BIN": os.getenv("REASONIX_BIN", "reasonix"),
            "CLAUDE_CODEX_REASONIX_MODEL": os.getenv("CLAUDE_REASONIX_REASONIX_MODEL", os.getenv("CLAUDE_CODEX_REASONIX_MODEL", "deepseek-v4-flash")),
            "CLAUDE_CODEX_REASONIX_COST_LEDGER": os.path.join(runtime_dir, "reasonix-cost.jsonl"),
        },
    }
}

with open(path, "w", encoding="utf-8") as fh:
    json.dump({"mcpServers": servers}, fh, indent=2)
    fh.write("\n")
PY
  printf '%s\n' "$MCP_FILE"
}

generate_agents() {
  ensure_dirs
  python3 - "$AGENTS_FILE" <<'PY'
import json
import os
import sys

path = sys.argv[1]
reasonix_model = os.getenv("CLAUDE_REASONIX_NATIVE_REASONIX_MODEL", os.getenv("CLAUDE_CODEX_NATIVE_REASONIX_MODEL", "claude-reasonix-flash"))
tools = [
    item.strip()
    for item in os.getenv("CLAUDE_REASONIX_NATIVE_AGENT_TOOLS", os.getenv("CLAUDE_CODEX_NATIVE_AGENT_TOOLS", "Read,Grep,Glob,Bash,Edit,Write,MultiEdit")).split(",")
    if item.strip()
]

def agent(description, prompt, model):
    return {
        "description": description,
        "prompt": prompt,
        "tools": tools,
        "disallowedTools": ["Agent", "Task"],
        "model": model,
        "effort": "xhigh",
        "permissionMode": "acceptEdits",
    }

# PREFIX-CACHE STABILITY: every agent type MUST share a byte-identical system
# prompt so all lanes in a fan-out belong to ONE DeepSeek prefix family. The old
# per-role suffix ("Focus especially on security…") sat ~char 355 — inside the
# first 4KB — so each agent type became its own prefix family (measured: 5 families
# on a real run → weighted cache 89.76%). Role focus now lives in this SHARED base
# (uniform for all) instead of a per-agent suffix; lane-specific intent already
# arrives via the task tail + the distinct `description` Claude routes on. The
# `description` differs per agent (routing only — NOT sent to the model), so
# fan-out behaviour is unchanged; only the cached prefix is unified.
reasonix_prompt = (
    "You are a native Claude Code subagent backed by Reasonix (DeepSeek) through "
    "the local claude-reasonix gateway. Do the worker-lane task directly with the "
    "available repository tools. Use fast, decisive coding-agent behavior, preserve "
    "user changes, and return concise evidence-backed results. Match your focus to "
    "the lane: for security lanes weigh exploitability and remediation; for review "
    "lanes weigh bugs, regressions, and missing tests; for verification lanes run or "
    "design targeted checks and report exact commands and outcomes; for deep/"
    "architecture lanes weigh system boundaries, data/API flows, and operational risk."
)

agents = {
    "reasonix-worker": agent(
        "General Reasonix worker for implementation, file analysis, repo search, and focused worker lanes.",
        reasonix_prompt,
        reasonix_model,
    ),
    "reasonix-security": agent(
        "Reasonix security review worker. Use for security, auth, secrets, permissions, injection, and abuse-case lanes.",
        reasonix_prompt,
        reasonix_model,
    ),
    "reasonix-reviewer": agent(
        "Reasonix code-review worker. Use for CodeReview lanes, regression checks, architecture/infra review, and independent diff review.",
        reasonix_prompt,
        reasonix_model,
    ),
    "reasonix-verify": agent(
        "Reasonix verification worker. Use for test, verify, reproduction, and acceptance-criteria lanes.",
        reasonix_prompt,
        reasonix_model,
    ),
}

with open(path, "w", encoding="utf-8") as fh:
    json.dump(agents, fh, indent=2)
    fh.write("\n")
PY
  printf '%s\n' "$AGENTS_FILE"
}

agents_json() {
  generate_agents >/dev/null
  python3 - "$AGENTS_FILE" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as fh:
    print(json.dumps(json.load(fh), separators=(",", ":")))
PY
}

generate_ccr_agents() {
  ensure_dirs
  python3 - "$CCR_AGENTS_FILE" <<'PY'
import json
import os
import sys

path = sys.argv[1]
reasonix_ccr_model = os.getenv("CLAUDE_REASONIX_CCR_CODEX_MODEL", os.getenv("CLAUDE_CODEX_CCR_CODEX_MODEL", "claude-reasonix-flash"))
deepseek_model = os.getenv("CLAUDE_REASONIX_CCR_DEEPSEEK_MODEL", os.getenv("CLAUDE_CODEX_CCR_DEEPSEEK_MODEL", "claude-reasonix-flash"))
qwen_model = os.getenv("CLAUDE_REASONIX_CCR_QWEN_MODEL", os.getenv("CLAUDE_CODEX_CCR_QWEN_MODEL", "qwen36-mlx"))
reasonix_ccr_route = os.getenv("CLAUDE_REASONIX_CCR_CODEX_ROUTE", os.getenv("CLAUDE_CODEX_CCR_CODEX_ROUTE", "codex-gateway,claude-reasonix-flash"))
deepseek_route = os.getenv("CLAUDE_REASONIX_CCR_DEEPSEEK_ROUTE", os.getenv("CLAUDE_CODEX_CCR_DEEPSEEK_ROUTE", "codex-gateway,claude-reasonix-flash"))
qwen_route = os.getenv("CLAUDE_REASONIX_CCR_QWEN_ROUTE", os.getenv("CLAUDE_CODEX_CCR_QWEN_ROUTE", f"qwen36-local,{qwen_model}"))
tools = [
    item.strip()
    for item in os.getenv("CLAUDE_REASONIX_NATIVE_AGENT_TOOLS", os.getenv("CLAUDE_CODEX_NATIVE_AGENT_TOOLS", "Read,Grep,Glob,Bash,Edit,Write,MultiEdit")).split(",")
    if item.strip()
]


def with_ccr_tag(route, text):
    return f"<CCR-SUBAGENT-MODEL>{route}</CCR-SUBAGENT-MODEL>\n{text}"


def agent(description, prompt, model):
    return {
        "description": description,
        "prompt": prompt,
        "tools": tools,
        "disallowedTools": ["Agent", "Task"],
        "model": model,
        "effort": "xhigh",
        "permissionMode": "acceptEdits",
    }


reasonix_ccr_prompt = with_ccr_tag(
    reasonix_ccr_route,
    (
        "You are a native Claude Code subagent routed by Claude Code Router to "
        "Reasonix through the claude-reasonix local gateway. Do the worker-lane task "
        "directly with the available repository tools. Use fast, decisive "
        "coding-agent behavior, preserve user changes, and return concise "
        "evidence-backed results."
    ),
)
deepseek_prompt = with_ccr_tag(
    deepseek_route,
    (
        "You are a native Claude Code subagent routed by Claude Code Router to "
        "DeepSeek through the claude-reasonix local gateway. Prefer broad "
        "architectural reasoning, database/API analysis, and deep review. Use "
        "repository tools when needed and keep the final output compact and "
        "actionable."
    ),
)
qwen_prompt = with_ccr_tag(
    qwen_route,
    (
        "You are a native Claude Code subagent routed by Claude Code Router to "
        "the user's local Qwen3.6 MLX stack. Use concise, tool-aware coding "
        "agent behavior. Prefer local analysis, repository search, and "
        "structured findings that the main Claude agent can verify cheaply."
    ),
)

agents = {
    "reasonix-worker": agent(
        "General Reasonix worker for implementation, file analysis, repo search, and focused worker lanes.",
        reasonix_ccr_prompt,
        reasonix_ccr_model,
    ),
    # Prefix-cache stability: keep the per-ROUTE base (reasonix/qwen genuinely route
    # to different models) but drop the per-ROLE suffix that used to fork a fresh
    # prefix family per agent type. Role intent rides the task tail + the distinct
    # `description` Claude routes on; same-route lanes now share one prefix.
    "reasonix-security": agent(
        "Reasonix security review worker. Use for security, auth, secrets, permissions, injection, and abuse-case lanes.",
        reasonix_ccr_prompt,
        reasonix_ccr_model,
    ),
    "reasonix-reviewer": agent(
        "Reasonix code-review worker. Use for CodeReview lanes, regression checks, architecture/infra review, and independent diff review.",
        reasonix_ccr_prompt,
        reasonix_ccr_model,
    ),
    "reasonix-verify": agent(
        "Reasonix verification worker. Use for test, verify, reproduction, and acceptance-criteria lanes.",
        reasonix_ccr_prompt,
        reasonix_ccr_model,
    ),
    "qwen-worker": agent(
        "Local Qwen3.6 worker. Use for cheap repo exploration, broad search, first-pass bug hunting, and local reasoning lanes.",
        qwen_prompt,
        qwen_model,
    ),
    "qwen-research": agent(
        "Local Qwen3.6 research worker. Use for deep local research, source gathering through allowed tools, and compact evidence summaries.",
        qwen_prompt + "\n\nReturn compact evidence and explicit uncertainty; avoid long narrative unless requested.",
        qwen_model,
    ),
}

with open(path, "w", encoding="utf-8") as fh:
    json.dump(agents, fh, indent=2)
    fh.write("\n")
PY
  printf '%s\n' "$CCR_AGENTS_FILE"
}

ccr_agents_json() {
  generate_ccr_agents >/dev/null
  python3 - "$CCR_AGENTS_FILE" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as fh:
    print(json.dumps(json.load(fh), separators=(",", ":")))
PY
}

generate_ccr_config() {
  ensure_dirs
  mkdir -p "$CCR_CONFIG_DIR"
  local ccr_port="${1:-${CLAUDE_REASONIX_CCR_PORT:-${CLAUDE_CODEX_CCR_PORT:-3456}}}"
  local gateway_url="${2:-${NATIVE_GATEWAY_URL:-http://127.0.0.1:65535}}"
  python3 - "$CCR_CONFIG_FILE" "$CCR_CUSTOM_ROUTER_FILE" "$ccr_port" "$gateway_url" <<'PY'
import json
import os
import sys
from pathlib import Path

config_path = Path(sys.argv[1])
router_path = Path(sys.argv[2])
ccr_port = int(sys.argv[3])
gateway_url = sys.argv[4].rstrip("/")

api_key = os.getenv("CLAUDE_REASONIX_CCR_API_KEY", os.getenv("CLAUDE_CODEX_CCR_API_KEY", "claude-codex-router"))
main_model = os.getenv("CLAUDE_REASONIX_ROUTER_MAIN_MODEL", os.getenv("CLAUDE_CODEX_ROUTER_MAIN_MODEL", "claude-opus-4-8"))
qwen_model = os.getenv("CLAUDE_REASONIX_CCR_QWEN_MODEL", os.getenv("CLAUDE_CODEX_CCR_QWEN_MODEL", "qwen36-mlx"))
qwen_models = [
    item.strip()
    for item in os.getenv("CLAUDE_REASONIX_CCR_QWEN_MODELS", os.getenv("CLAUDE_CODEX_CCR_QWEN_MODELS", qwen_model)).split(",")
    if item.strip()
]
if qwen_model not in qwen_models:
    qwen_models.insert(0, qwen_model)
main_provider = "qwen36-local" if main_model in qwen_models else "anthropic"
anthropic_key = (
    os.getenv("CLAUDE_REASONIX_ANTHROPIC_API_KEY", os.getenv("CLAUDE_CODEX_ANTHROPIC_API_KEY"))
    or os.getenv("ANTHROPIC_API_KEY")
    or os.getenv("ANTHROPIC_AUTH_TOKEN")
    or "missing-anthropic-api-key"
)
anthropic_models = [
    item.strip()
    for item in os.getenv(
        "CLAUDE_CODEX_ANTHROPIC_MODELS",
        "claude-opus-4-8,claude-sonnet-4-6,claude-haiku-4-5,claude-opus-4-5,claude-sonnet-4-5",
    ).split(",")
    if item.strip()
]
if main_provider == "anthropic" and main_model not in anthropic_models:
    anthropic_models.insert(0, main_model)

providers = [
    {
        "name": "anthropic",
        "api_base_url": os.getenv("CLAUDE_REASONIX_ANTHROPIC_BASE_URL", os.getenv("CLAUDE_CODEX_ANTHROPIC_BASE_URL", "https://api.anthropic.com/v1/messages")),
        "api_key": anthropic_key,
        "models": anthropic_models,
        "transformer": {"use": ["Anthropic"]},
    },
    {
        "name": "codex-gateway",
        "api_base_url": gateway_url + "/v1/chat/completions",
        "api_key": "local-gateway",
        "models": [os.getenv("CLAUDE_REASONIX_CCR_CODEX_MODEL", os.getenv("CLAUDE_CODEX_CCR_CODEX_MODEL", "claude-reasonix-flash"))],
    },
    {
        "name": "deepseek-gateway",
        "api_base_url": gateway_url + "/v1/chat/completions",
        "api_key": "local-gateway",
        "models": [os.getenv("CLAUDE_REASONIX_CCR_DEEPSEEK_MODEL", os.getenv("CLAUDE_CODEX_CCR_DEEPSEEK_MODEL", "claude-reasonix-flash"))],
    },
    {
        "name": "qwen36-local",
        "api_base_url": os.getenv("CLAUDE_REASONIX_QWEN_ANTHROPIC_BASE_URL", os.getenv("CLAUDE_CODEX_QWEN_ANTHROPIC_BASE_URL", "http://127.0.0.1:14000/v1/messages")),
        "api_key": os.getenv("CLAUDE_REASONIX_QWEN_API_KEY", os.getenv("CLAUDE_CODEX_QWEN_API_KEY", "sk-local-qwen36")),
        "models": qwen_models,
        "transformer": {"use": ["Anthropic"]},
    },
]

config = {
    "LOG": os.getenv("CLAUDE_REASONIX_CCR_LOG", os.getenv("CLAUDE_CODEX_CCR_LOG", "false")).lower() in {"1", "true", "yes", "on"},
    "HOST": os.getenv("CLAUDE_REASONIX_CCR_HOST", os.getenv("CLAUDE_CODEX_CCR_HOST", "127.0.0.1")),
    "PORT": ccr_port,
    "APIKEY": api_key,
    "API_TIMEOUT_MS": int(os.getenv("CLAUDE_REASONIX_CCR_TIMEOUT_MS", os.getenv("CLAUDE_CODEX_CCR_TIMEOUT_MS", "600000"))),
    "Providers": providers,
    "providers": providers,
    "Router": {
        "default": f"{main_provider},{main_model}",
        "think": f"{main_provider},{main_model}",
        "longContext": f"{main_provider},{main_model}",
        "longContextThreshold": int(os.getenv("CLAUDE_REASONIX_CCR_LONG_CONTEXT_THRESHOLD", os.getenv("CLAUDE_CODEX_CCR_LONG_CONTEXT_THRESHOLD", "60000"))),
    },
    "CUSTOM_ROUTER_PATH": str(router_path),
}

# Map each gateway-served model name to its "provider,model" route, derived
# from the ACTUAL provider definitions above (the gateway / deepseek providers).
# In reasonix flavor these models are claude-reasonix-flash, which begins with
# "claude" and would otherwise fall through to the anthropic fallback below and
# 401 with an invalid x-api-key. This explicit table routes whatever model the
# local gateway providers serve to the gateway, regardless of its name.
gateway_routes = {}
for _prov in providers:
    if _prov.get("name") in ("codex-gateway", "deepseek-gateway"):
        for _m in _prov.get("models", []):
            if _m:
                gateway_routes[_m] = f"{_prov['name']},{_m}"

router_source = """
const qwenModels = new Set(__QWEN_MODELS__);
const gatewayRoutes = __GATEWAY_ROUTES__;

module.exports = async function claudeReasonixRouter(req) {
  const body = req.body || {};
  const system = Array.isArray(body.system) ? body.system : [];
  const subagentPrompt = system[1] && typeof system[1].text === "string" ? system[1].text : "";
  if (subagentPrompt.startsWith("<CCR-SUBAGENT-MODEL>")) {
    return null;
  }
  const model = typeof req.body.model === "string" ? req.body.model : "";
  if (model.includes(",")) {
    return model;
  }
  if (model === "claude-reasonix-flash") {
    return "codex-gateway,claude-reasonix-flash";
  }
  if (qwenModels.has(model)) {
    return "qwen36-local," + model;
  }
  if (Object.prototype.hasOwnProperty.call(gatewayRoutes, model)) {
    return gatewayRoutes[model];
  }
  if (model.startsWith("claude") || model.startsWith("anthropic")) {
    return "anthropic," + model;
  }
  return null;
};
""".replace("__QWEN_MODELS__", json.dumps(qwen_models)).replace("__GATEWAY_ROUTES__", json.dumps(gateway_routes)).lstrip()

config_path.parent.mkdir(parents=True, exist_ok=True)
config_path.write_text(json.dumps(config, indent=2) + "\n", encoding="utf-8")
router_path.write_text(router_source, encoding="utf-8")
PY
  printf '%s\n' "$CCR_CONFIG_FILE"
}

start_native_gateway() {
  ensure_dirs
  [[ -f "$GATEWAY_FILE" ]] || {
    echo "missing native gateway: $GATEWAY_FILE" >&2
    exit 1
  }

  local host="${CLAUDE_REASONIX_GATEWAY_HOST:-${CLAUDE_CODEX_GATEWAY_HOST:-127.0.0.1}}"
  local port="${CLAUDE_REASONIX_GATEWAY_PORT:-${CLAUDE_CODEX_GATEWAY_PORT:-0}}"
  local port_file="$RUNTIME_DIR/gateway.$$.port"
  local log_file="$RUNTIME_DIR/gateway.log"
  local upstream_base="${CLAUDE_REASONIX_GATEWAY_ANTHROPIC_BASE_URL:-${CLAUDE_CODEX_GATEWAY_ANTHROPIC_BASE_URL:-${ANTHROPIC_BASE_URL:-https://api.anthropic.com}}}"
  local gateway_concurrency="${CLAUDE_REASONIX_GATEWAY_CODEX_CONCURRENCY:-${CLAUDE_CODEX_GATEWAY_CODEX_CONCURRENCY:-$(current_workers)}}"
  rm -f "$port_file"

  CLAUDE_CODEX_GATEWAY_ANTHROPIC_BASE_URL="$upstream_base" \
    CLAUDE_CODEX_GATEWAY_CODEX_CONCURRENCY="$gateway_concurrency" \
    python3 "$GATEWAY_FILE" --host "$host" --port "$port" --port-file "$port_file" >>"$log_file" 2>&1 &
  NATIVE_GATEWAY_PID="$!"

  local i
  for i in {1..100}; do
    if [[ -s "$port_file" ]]; then
      local actual_port
      actual_port="$(tr -d '[:space:]' < "$port_file")"
      NATIVE_GATEWAY_URL="http://$host:$actual_port"
      rm -f "$port_file"
      return 0
    fi
    if ! kill -0 "$NATIVE_GATEWAY_PID" 2>/dev/null; then
      echo "native gateway exited before startup; see $log_file" >&2
      exit 1
    fi
    sleep 0.05
  done

  echo "native gateway did not start; see $log_file" >&2
  kill "$NATIVE_GATEWAY_PID" 2>/dev/null || true
  exit 1
}

stop_native_gateway() {
  if [[ -n "${NATIVE_GATEWAY_PID:-}" ]] && kill -0 "$NATIVE_GATEWAY_PID" 2>/dev/null; then
    kill "$NATIVE_GATEWAY_PID" 2>/dev/null || true
    wait "$NATIVE_GATEWAY_PID" 2>/dev/null || true
  fi
  NATIVE_GATEWAY_PID=""
  NATIVE_GATEWAY_URL=""
}

find_free_port() {
  python3 - <<'PY'
import socket

with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
    sock.bind(("127.0.0.1", 0))
    print(sock.getsockname()[1])
PY
}

start_ccr_service() {
  local port="$1"
  local log_file="$RUNTIME_DIR/ccr.log"
  mkdir -p "$CCR_CONFIG_DIR"

  HOME="$CCR_HOME" "$CCR_BIN" stop >>"$log_file" 2>&1 || true
  HOME="$CCR_HOME" "$CCR_BIN" start >>"$log_file" 2>&1 &
  CCR_SERVICE_PID="$!"

  case "$(basename "$CCR_BIN")" in
    echo)
      wait "$CCR_SERVICE_PID" 2>/dev/null || true
      CCR_SERVICE_PID=""
      return 0
      ;;
  esac

  python3 - "$port" "$log_file" "$CCR_SERVICE_PID" <<'PY'
import os
import sys
import time
import urllib.error
import urllib.request

port = sys.argv[1]
log_file = sys.argv[2]
pid = int(sys.argv[3])
url = f"http://127.0.0.1:{port}/health"
for _ in range(100):
    try:
        with urllib.request.urlopen(url, timeout=0.5) as response:
            if response.status < 500:
                raise SystemExit(0)
    except Exception:
        try:
            os.kill(pid, 0)
        except OSError:
            break
        time.sleep(0.05)
raise SystemExit(f"Claude Code Router did not become healthy; see {log_file}")
PY
}

stop_ccr_service() {
  local log_file="$RUNTIME_DIR/ccr.log"
  HOME="$CCR_HOME" "$CCR_BIN" stop >>"$log_file" 2>&1 || true
  if [[ -n "${CCR_SERVICE_PID:-}" ]] && kill -0 "$CCR_SERVICE_PID" 2>/dev/null; then
    kill "$CCR_SERVICE_PID" 2>/dev/null || true
    wait "$CCR_SERVICE_PID" 2>/dev/null || true
  fi
  CCR_SERVICE_PID=""
}

ccr_model_list() {
  python3 - "$CCR_CONFIG_FILE" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as fh:
    config = json.load(fh)
seen = set()
models = []
for provider in config.get("Providers", []):
    for model in provider.get("models", []):
        if model not in seen:
            seen.add(model)
            models.append(model)
print(",".join(models))
PY
}

ccr_alias_model_list() {
  python3 - "$CCR_CONFIG_FILE" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as fh:
    config = json.load(fh)
aliases = []
for provider in config.get("Providers", []):
    if provider.get("name") in {"codex-gateway", "deepseek-gateway", "qwen36-local"}:
        aliases.extend(provider.get("models", []))
print(",".join(dict.fromkeys(aliases)))
PY
}

ensure_qwen36_ready() {
  case "${CLAUDE_REASONIX_QWEN_SKIP_START:-${CLAUDE_CODEX_QWEN_SKIP_START:-0}}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
  esac

  local base
  base="${CLAUDE_REASONIX_QWEN_HEALTH_URL:-${CLAUDE_CODEX_QWEN_HEALTH_URL:-http://127.0.0.1:14000/health}}"
  if curl -fsS "$base" >/dev/null 2>&1; then
    return 0
  fi

  if command -v qwen36 >/dev/null 2>&1; then
    qwen36 start
    curl -fsS "$base" >/dev/null 2>&1 && return 0
  fi

  echo "local Qwen3.6 shim is not ready at $base; run: qwen36 start" >&2
  exit 1
}

start_ccr_proxy() {
  local proxy_port="$1"
  local ccr_port="$2"
  local ccr_api_key="${3-claude-codex-router}"
  local passthrough_main="${4:-0}"
  local port_file="$RUNTIME_DIR/ccr-proxy.$$.port"
  local log_file="$RUNTIME_DIR/ccr-proxy.log"
  local models
  models="$(ccr_model_list)"
  local aliases
  aliases="$(ccr_alias_model_list)"
  local proxy_args=(
    --host "127.0.0.1"
    --port "$proxy_port"
    --port-file "$port_file"
    --target "http://127.0.0.1:$ccr_port"
    --main-target "${CLAUDE_REASONIX_MAIN_ANTHROPIC_BASE_URL:-${CLAUDE_CODEX_MAIN_ANTHROPIC_BASE_URL:-https://api.anthropic.com}}"
    --api-key "$ccr_api_key"
    --models "$models"
    --alias-models "$aliases"
  )
  if [[ -n "${NATIVE_GATEWAY_URL:-}" ]]; then
    proxy_args+=(
      --direct-alias-target "$NATIVE_GATEWAY_URL"
      --direct-alias-models "${CLAUDE_REASONIX_DIRECT_ALIAS_MODELS:-${CLAUDE_CODEX_DIRECT_ALIAS_MODELS:-claude-reasonix-flash}}"
    )
  fi
  if [[ "$passthrough_main" == "1" ]]; then
    proxy_args+=(--passthrough-main)
  fi
  rm -f "$port_file"

  python3 "$CCR_PROXY_FILE" "${proxy_args[@]}" >>"$log_file" 2>&1 &
  CCR_PROXY_PID="$!"

  local i
  for i in {1..100}; do
    if [[ -s "$port_file" ]]; then
      local actual_port
      actual_port="$(tr -d '[:space:]' < "$port_file")"
      CCR_PROXY_URL="http://127.0.0.1:$actual_port"
      rm -f "$port_file"
      return 0
    fi
    if ! kill -0 "$CCR_PROXY_PID" 2>/dev/null; then
      echo "CCR Claude proxy exited before startup; see $log_file" >&2
      exit 1
    fi
    sleep 0.05
  done

  echo "CCR Claude proxy did not start; see $log_file" >&2
  kill "$CCR_PROXY_PID" 2>/dev/null || true
  exit 1
}

stop_ccr_proxy() {
  if [[ -n "${CCR_PROXY_PID:-}" ]] && kill -0 "$CCR_PROXY_PID" 2>/dev/null; then
    kill "$CCR_PROXY_PID" 2>/dev/null || true
    wait "$CCR_PROXY_PID" 2>/dev/null || true
  fi
  CCR_PROXY_PID=""
  CCR_PROXY_URL=""
}

allowed_tools_csv() {
  printf '%s\n' "mcp__reasonix_fleet__*"
}

bridge_prompt() {
  local workers
  workers="$(current_workers)"
  printf 'This Claude Code session is running Reasonix Fleet dynamic mode. Use the reasonix_fleet MCP server to dispatch any number of Reasonix CLI subagents. Default concurrent Reasonix tasks: %s.\n\n' "$workers"
  cat "$PROMPT_FILE"
}

router_prompt() {
  local workers
  workers="$(current_workers)"
  printf 'This Claude Code session is running explicit Claude Code Router mode. Ordinary non-subagent work stays in Claude Code and keeps the selected main Claude model. Native reasonix-* and deepseek-* worker lanes are routed by CCR tags to Reasonix/DeepSeek aliases. Reasonix Fleet MCP remains available as fallback with default concurrency %s.\n\n' "$workers"
  cat "$PROMPT_FILE"
}

run_claude_with_fleet() {
  [[ -f "$SETTINGS_FILE" ]] || {
    echo "missing bridge settings: $SETTINGS_FILE" >&2
    exit 1
  }
  [[ -f "$PROMPT_FILE" ]] || {
    echo "missing bridge prompt: $PROMPT_FILE" >&2
    exit 1
  }
  [[ -f "$MCP_SERVER_FILE" ]] || {
    echo "missing Reasonix Fleet MCP server: $MCP_SERVER_FILE" >&2
    exit 1
  }
  [[ -f "$CCR_PROXY_FILE" ]] || {
    echo "missing CCR Claude proxy: $CCR_PROXY_FILE" >&2
    exit 1
  }

  generate_config >/dev/null
  render_settings
  local prompt
  prompt="$(bridge_prompt)"
  local base_args=(
    --mcp-config "$MCP_FILE"
    --settings "$RENDERED_SETTINGS"
    --append-system-prompt "$prompt"
  )

  if native_subagents_enabled; then
    local agent_defs
    agent_defs="$(agents_json)"
    local forced_subagent_model="${CLAUDE_REASONIX_SUBAGENT_MODEL:-${CLAUDE_CODEX_SUBAGENT_MODEL:-${CLAUDE_CODEX_NATIVE_REASONIX_MODEL:-claude-reasonix-flash}}}"
    start_native_gateway
    set +e
    CLAUDE_CODEX_NATIVE_SUBAGENTS=1 \
      CLAUDE_CODEX_WORKFLOW_MODE=native \
      CLAUDE_CODE_SUBAGENT_MODEL="$forced_subagent_model" \
      ANTHROPIC_BASE_URL="$NATIVE_GATEWAY_URL" \
      CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY="${CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY:-1}" \
      ANTHROPIC_CUSTOM_MODEL_OPTION="${ANTHROPIC_CUSTOM_MODEL_OPTION:-claude-reasonix-flash}" \
      ANTHROPIC_CUSTOM_MODEL_OPTION_NAME="${ANTHROPIC_CUSTOM_MODEL_OPTION_NAME:-claude-reasonix-flash}" \
      ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION="${ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION:-Reasonix-backed native Claude Code subagent model}" \
      ANTHROPIC_CUSTOM_MODEL_OPTION_SUPPORTED_CAPABILITIES="${ANTHROPIC_CUSTOM_MODEL_OPTION_SUPPORTED_CAPABILITIES:-effort,xhigh_effort,thinking,interleaved_thinking}" \
      "$CLAUDE_BIN" \
        "${base_args[@]}" \
        --agents "$agent_defs" \
        "$@"
    local code=$?
    set -e
    stop_native_gateway
    return "$code"
  fi

  CLAUDE_CODEX_NATIVE_SUBAGENTS=0 \
    CLAUDE_CODEX_WORKFLOW_MODE=fleet \
    "$CLAUDE_BIN" \
    "${base_args[@]}" \
    --disallowedTools "Agent,Task" \
    "$@"
}

run_claude() {
  run_claude_with_fleet "$@"
}

run_claude_with_router() {
  local router_auth_mode="${1:-api}"
  shift || true
  prepare_router_runtime
  [[ -f "$SETTINGS_FILE" ]] || {
    echo "missing bridge settings: $SETTINGS_FILE" >&2
    exit 1
  }
  [[ -f "$PROMPT_FILE" ]] || {
    echo "missing bridge prompt: $PROMPT_FILE" >&2
    exit 1
  }
  [[ -f "$MCP_SERVER_FILE" ]] || {
    echo "missing Reasonix Fleet MCP server: $MCP_SERVER_FILE" >&2
    exit 1
  }

  local qwen_main_model="${CLAUDE_REASONIX_CCR_QWEN_MODEL:-${CLAUDE_CODEX_CCR_QWEN_MODEL:-qwen36-mlx}}"
  local selected_main_model=""
  if [[ "$router_auth_mode" == "qwen" ]]; then
    ensure_qwen36_ready
    selected_main_model="${CLAUDE_REASONIX_ROUTER_MAIN_MODEL:-${CLAUDE_CODEX_ROUTER_MAIN_MODEL:-$qwen_main_model}}"
  elif [[ "$router_auth_mode" == "api" && -z "${CLAUDE_REASONIX_ANTHROPIC_API_KEY:-${CLAUDE_CODEX_ANTHROPIC_API_KEY:-}}${ANTHROPIC_API_KEY:-}${ANTHROPIC_AUTH_TOKEN:-}" ]]; then
    echo "warning: claude-reasonix router mode needs an Anthropic API key/token for CCR to preserve the main Claude model route" >&2
  elif [[ "$router_auth_mode" == "login" ]]; then
    echo "warning: claude-reasonix router-login is experimental; it only works if Claude Code sends its login auth to the local gateway" >&2
  fi

  generate_config >/dev/null
  render_settings
  local prompt
  if [[ "$CLAUDE_REASONIX_FLAVOR" == "reasonix" && -f "$INSTALL_HOME/system-prompt-reasonix.md" ]]; then
    prompt="$(cat "$INSTALL_HOME/system-prompt-reasonix.md")"
  else
    prompt="$(router_prompt)"
  fi
  local base_args=(
    --mcp-config "$MCP_FILE"
    --settings "$RENDERED_SETTINGS"
    --append-system-prompt "$prompt"
  )

  local ccr_port
  ccr_port="${CLAUDE_REASONIX_CCR_PORT:-${CLAUDE_CODEX_CCR_PORT:-$(find_free_port)}}"
  local proxy_port
  proxy_port="${CLAUDE_REASONIX_CCR_PROXY_PORT:-${CLAUDE_CODEX_CCR_PROXY_PORT:-$(find_free_port)}}"
  local agent_defs
  agent_defs="$(ccr_agents_json)"
  local ccr_api_key="${CLAUDE_REASONIX_CCR_API_KEY:-${CLAUDE_CODEX_CCR_API_KEY-claude-codex-router}}"
  local passthrough_main=0
  if [[ "$router_auth_mode" == "login" ]]; then
    ccr_api_key="${CLAUDE_REASONIX_CCR_API_KEY:-${CLAUDE_CODEX_CCR_API_KEY-}}"
    passthrough_main=1
  fi
  local custom_model_option="${ANTHROPIC_CUSTOM_MODEL_OPTION:-claude-reasonix-flash}"
  local custom_model_option_name="${ANTHROPIC_CUSTOM_MODEL_OPTION_NAME:-$custom_model_option}"
  local custom_model_option_description="${ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION:-Reasonix-backed native Claude Code subagent model routed by CCR}"
  local forced_subagent_model="${CLAUDE_REASONIX_SUBAGENT_MODEL:-${CLAUDE_CODEX_SUBAGENT_MODEL:-${CLAUDE_CODEX_CCR_CODEX_MODEL:-claude-reasonix-flash}}}"
  if [[ "$router_auth_mode" == "qwen" ]]; then
    custom_model_option="${ANTHROPIC_CUSTOM_MODEL_OPTION:-$selected_main_model}"
    custom_model_option_name="${ANTHROPIC_CUSTOM_MODEL_OPTION_NAME:-$selected_main_model}"
    custom_model_option_description="${ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION:-Local Qwen3.6 model routed by CCR}"
  fi

  start_native_gateway
  if [[ "$router_auth_mode" == "qwen" ]]; then
    CLAUDE_CODEX_CCR_API_KEY="$ccr_api_key" \
      CLAUDE_CODEX_ROUTER_MAIN_MODEL="$selected_main_model" \
      generate_ccr_config "$ccr_port" "$NATIVE_GATEWAY_URL" >/dev/null
  else
    CLAUDE_CODEX_CCR_API_KEY="$ccr_api_key" generate_ccr_config "$ccr_port" "$NATIVE_GATEWAY_URL" >/dev/null
  fi
  start_ccr_service "$ccr_port"
  start_ccr_proxy "$proxy_port" "$ccr_port" "$ccr_api_key" "$passthrough_main"

  set +e
  if [[ "$router_auth_mode" == "login" ]]; then
      env -u ANTHROPIC_AUTH_TOKEN -u ANTHROPIC_API_KEY \
      CLAUDE_CODEX_NATIVE_SUBAGENTS=1 \
      CLAUDE_CODEX_WORKFLOW_MODE=router \
      CLAUDE_CODE_SUBAGENT_MODEL="$forced_subagent_model" \
      CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY="${CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY:-1}" \
      ANTHROPIC_BASE_URL="$CCR_PROXY_URL" \
      ANTHROPIC_CUSTOM_MODEL_OPTION="$custom_model_option" \
      ANTHROPIC_CUSTOM_MODEL_OPTION_NAME="$custom_model_option_name" \
      ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION="$custom_model_option_description" \
      ANTHROPIC_CUSTOM_MODEL_OPTION_SUPPORTED_CAPABILITIES="${ANTHROPIC_CUSTOM_MODEL_OPTION_SUPPORTED_CAPABILITIES:-effort,xhigh_effort,thinking,interleaved_thinking}" \
      NO_PROXY="${NO_PROXY:-127.0.0.1,localhost}" \
      "$CLAUDE_BIN" \
        "${base_args[@]}" \
        --agents "$agent_defs" \
        "$@"
  else
    local claude_args=("${base_args[@]}" --agents "$agent_defs")
    if [[ -n "$selected_main_model" ]]; then
      claude_args+=(--model "$selected_main_model")
    fi
    CLAUDE_CODEX_NATIVE_SUBAGENTS=1 \
      CLAUDE_CODEX_WORKFLOW_MODE=router \
      CLAUDE_CODE_SUBAGENT_MODEL="$forced_subagent_model" \
      CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY="${CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY:-1}" \
      ANTHROPIC_BASE_URL="$CCR_PROXY_URL" \
      ANTHROPIC_AUTH_TOKEN="$ccr_api_key" \
      ANTHROPIC_CUSTOM_MODEL_OPTION="$custom_model_option" \
      ANTHROPIC_CUSTOM_MODEL_OPTION_NAME="$custom_model_option_name" \
      ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION="$custom_model_option_description" \
      ANTHROPIC_CUSTOM_MODEL_OPTION_SUPPORTED_CAPABILITIES="${ANTHROPIC_CUSTOM_MODEL_OPTION_SUPPORTED_CAPABILITIES:-effort,xhigh_effort,thinking,interleaved_thinking}" \
      NO_PROXY="${NO_PROXY:-127.0.0.1,localhost}" \
      "$CLAUDE_BIN" \
        "${claude_args[@]}" \
        "$@"
  fi
  local code=$?
  set -e
  stop_ccr_proxy
  stop_ccr_service
  stop_native_gateway
  cleanup_router_runtime
  return "$code"
}

run_plain_claude() {
  exec "$CLAUDE_BIN" "$@"
}

run_task() {
  ensure_dirs
  [[ "$#" -gt 0 ]] || {
    echo "usage: claude-reasonix task <prompt or claude -p args>" >&2
    exit 2
  }
  rm -f "$ENABLED_FILE"
  set +e
  run_claude_with_fleet -p "$@"
  local code=$?
  set -e
  rm -f "$ENABLED_FILE"
  return "$code"
}

process_list() {
  if [[ -n "${CLAUDE_REASONIX_PS_FIXTURE:-${CLAUDE_CODEX_PS_FIXTURE:-}}" ]]; then
    cat "${CLAUDE_REASONIX_PS_FIXTURE:-${CLAUDE_CODEX_PS_FIXTURE:-}}"
  else
    ps -axo pid=,command=
  fi
}

report_active_sessions() {
  python3 - "$MCP_FILE" "${CLAUDE_REASONIX_CODEX_MODEL:-${CLAUDE_CODEX_CODEX_MODEL:-${REASONIX_FLEET_MODEL:-gpt-5.4}}}" "$(current_workers)" "${CLAUDE_REASONIX_PS_FIXTURE:-${CLAUDE_CODEX_PS_FIXTURE:-}}" <<'PY'
import re
import subprocess
import sys

mcp_file, expected_model, expected_concurrency, fixture = sys.argv[1:]
expected_lower = expected_model.lower()
sessions = []

if fixture:
    with open(fixture, "r", encoding="utf-8", errors="replace") as fh:
        lines = fh.readlines()
else:
    result = subprocess.run(
        ["ps", "-axo", "pid=,command="],
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
    lines = result.stdout.splitlines()

for raw_line in lines:
    line = raw_line.strip()
    if not line:
        continue
    parts = line.split(None, 1)
    if len(parts) != 2 or not parts[0].isdigit():
        continue
    pid, command = parts
    if "--mcp-config" not in command or mcp_file not in command:
        continue
    if "claude" not in command:
        continue

    lowered = command.lower()
    if "--agents" in command or "router mode" in lowered or "ccr" in lowered:
        mode = "router"
    elif "--disallowedTools" in command or "--disallowedtools" in lowered:
        mode = "fleet"
    else:
        mode = "unknown"

    fields = [f"pid={pid}", f"mode={mode}"]
    restart_required = False
    if "gpt-5.5" in lowered:
        fields.append("stale_model=gpt-5.5")
        fields.append("restart required")
        restart_required = True
    elif expected_lower in lowered:
        fields.append(f"model={expected_model}")
    else:
        fields.append("model=unknown")

    concurrency_match = (
        re.search(r"default concurrency (\d+)", lowered)
        or re.search(r"default concurrent reasonix tasks: (\d+)", lowered)
    )
    if concurrency_match:
        active_concurrency = concurrency_match.group(1)
        if active_concurrency != expected_concurrency:
            fields.append(f"stale_concurrency={active_concurrency}")
            fields.append("restart required")
            restart_required = True
        else:
            fields.append(f"concurrency={active_concurrency}")
    sessions.append(("  " + " ".join(fields), restart_required))

if sessions:
    print("active claude-reasonix sessions:")
    for text, _ in sessions:
        print(text)
    if any(restart for _, restart in sessions):
        print("warning: restart required for stale claude-reasonix sessions to use the current model/config")
PY
}

status() {
  ensure_dirs
  if is_enabled; then
    echo "reasonix fleet: enabled"
  else
  echo "reasonix fleet: disabled"
  fi
  echo "default concurrency: $(current_workers)"
  echo "gateway concurrency: ${CLAUDE_REASONIX_GATEWAY_CODEX_CONCURRENCY:-${CLAUDE_CODEX_GATEWAY_CODEX_CONCURRENCY:-$(current_workers)}}"
  echo "fleet home: $FLEET_HOME"
  echo "install home: $INSTALL_HOME"
  report_active_sessions
}

doctor() {
  local ok=0
  [[ -f "$SETTINGS_FILE" ]] || { echo "missing $SETTINGS_FILE" >&2; ok=1; }
  [[ -f "$PROMPT_FILE" ]] || { echo "missing $PROMPT_FILE" >&2; ok=1; }
  [[ -f "$INSTALL_HOME/hooks/only-reasonix-fleet.py" ]] || { echo "missing guard hook" >&2; ok=1; }
  [[ -f "$INSTALL_HOME/hooks/reasonix-workflow.py" ]] || { echo "missing workflow hook" >&2; ok=1; }
  [[ -f "$MCP_SERVER_FILE" ]] || { echo "missing $MCP_SERVER_FILE" >&2; ok=1; }
  [[ -f "$GATEWAY_FILE" ]] || { echo "missing $GATEWAY_FILE" >&2; ok=1; }
  [[ -f "$CCR_PROXY_FILE" ]] || { echo "missing $CCR_PROXY_FILE" >&2; ok=1; }
  python3 -m json.tool "$SETTINGS_FILE" >/dev/null || ok=1
  generate_config >/dev/null || ok=1
  generate_agents >/dev/null || ok=1
  generate_ccr_agents >/dev/null || ok=1
  generate_ccr_config >/dev/null || ok=1
  python3 -m json.tool "$MCP_FILE" >/dev/null || ok=1
  python3 -m json.tool "$AGENTS_FILE" >/dev/null || ok=1
  python3 -m json.tool "$CCR_AGENTS_FILE" >/dev/null || ok=1
  python3 -m json.tool "$CCR_CONFIG_FILE" >/dev/null || ok=1
  python3 -m py_compile "$MCP_SERVER_FILE" || ok=1
  python3 -m py_compile "$GATEWAY_FILE" || ok=1
  python3 -m py_compile "$CCR_PROXY_FILE" || ok=1
  "$CLAUDE_BIN" --version >/dev/null || { echo "claude command failed" >&2; ok=1; }
  command -v reasonix >/dev/null || { echo "reasonix command not found" >&2; ok=1; }
  report_active_sessions
  if (( ok == 0 )); then
    echo "reasonix fleet doctor: ok"
  fi
  exit "$ok"
}

main() {
  local command="${1:-run}"
  case "$command" in
    on)
      shift
      ensure_dirs
      if [[ "${1:-}" != "" ]]; then
        set_workers "$1"
      elif [[ ! -f "$WORKERS_FILE" ]]; then
        set_workers "$DEFAULT_WORKERS"
      fi
      touch "$ENABLED_FILE"
      generate_config >/dev/null
      status
      ;;
    off)
      shift || true
      ensure_dirs
      rm -f "$ENABLED_FILE"
      status
      ;;
    status)
      shift || true
      status
      ;;
    workers)
      shift
      [[ "${1:-}" != "" ]] || {
        echo "usage: claude-reasonix workers <count>" >&2
        exit 2
      }
      set_workers "$1"
      generate_config >/dev/null
      status
      ;;
    task|once)
      shift || true
      run_task "$@"
      ;;
    generate-config)
      shift || true
      generate_config
      ;;
    generate-agents)
      shift || true
      generate_agents
      ;;
    generate-ccr-agents)
      shift || true
      generate_ccr_agents
      ;;
    generate-ccr-config)
      shift || true
      generate_ccr_config
      ;;
    doctor)
      shift || true
      doctor
      ;;
    cost)
      shift || true
      LEDGER="${CLAUDE_REASONIX_REASONIX_COST_LEDGER:-${CLAUDE_CODEX_REASONIX_COST_LEDGER:-$RUNTIME_DIR/reasonix-cost.jsonl}}"
      python3 - "$GATEWAY_FILE" "$LEDGER" <<'PY'
import importlib.util, sys
spec = importlib.util.spec_from_file_location("g", sys.argv[1])
g = importlib.util.module_from_spec(spec); spec.loader.exec_module(g)
s = g.summarize_reasonix_cost(sys.argv[2])
if s["lanes"] == 0:
    print("Reasonix cost: no lanes recorded yet (ledger: %s)" % sys.argv[2])
else:
    print("Reasonix cost (ledger: %s)" % sys.argv[2])
    print("  lanes: %d | total: $%.4f | avg/lane: $%.6f" % (s["lanes"], s["total_usd"], s["avg_per_lane_usd"]))
    print("  cache: %.1f%% avg | tokens: %d in / %d out" % (s["avg_cache_pct"], s["input_tokens"], s["output_tokens"]))
    if s["claude_equiv_usd"] > 0:
        print("  vs Claude: would be $%.4f -> saved ~$%.4f (%.1f%%)" % (s["claude_equiv_usd"], s["saved_usd"], s["saved_pct"]))
PY
      ;;
    router|ccr)
      shift || true
      run_claude_with_router api "$@"
      ;;
    router-login|ccr-login|router-subscription)
      shift || true
      run_claude_with_router login "$@"
      ;;
    router-qwen|ccr-qwen|qwen-router)
      shift || true
      run_claude_with_router qwen "$@"
      ;;
    run)
      shift || true
      run_claude "$@"
      ;;
    plain|claude)
      shift || true
      run_plain_claude "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      run_claude "$@"
      ;;
  esac
}

main "$@"
