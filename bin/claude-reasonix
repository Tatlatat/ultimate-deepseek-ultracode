#!/usr/bin/env bash
set -euo pipefail

INSTALL_HOME="${CLAUDE_REASONIX_FLEET_INSTALL_HOME:-${CLAUDE_CODEX_FLEET_INSTALL_HOME:-$HOME/.claude/reasonix-fleet}}"
FLEET_HOME="${CLAUDE_REASONIX_FLEET_HOME:-${CLAUDE_CODEX_FLEET_HOME:-$INSTALL_HOME}}"
STATE_DIR="$FLEET_HOME/state"
RUNTIME_DIR="$FLEET_HOME/runtime"
ENABLED_FILE="$STATE_DIR/enabled"
WORKERS_FILE="$STATE_DIR/workers"
MCP_FILE="$RUNTIME_DIR/mcp.json"
SETTINGS_FILE="$INSTALL_HOME/bridge-settings.json"
RENDERED_SETTINGS="$RUNTIME_DIR/bridge-settings.rendered.json"
PROMPT_FILE="$INSTALL_HOME/system-prompt-reasonix.md"
MCP_SERVER_FILE="$INSTALL_HOME/reasonix-fleet-mcp.py"
GATEWAY_FILE="$INSTALL_HOME/reasonix-native-gateway.py"
AGENTS_FILE="$RUNTIME_DIR/agents.json"

CLAUDE_BIN="${CLAUDE_BIN:-claude}"
# The reasonix CLI binary the Fleet MCP shells out to. Back-compat: honor a legacy
# CODEX_BIN if set, but the canonical name is REASONIX_BIN.
REASONIX_BIN="${REASONIX_BIN:-${CODEX_BIN:-reasonix}}"
DEFAULT_WORKERS="${CLAUDE_REASONIX_FLEET_DEFAULT_WORKERS:-${CLAUDE_CODEX_FLEET_DEFAULT_WORKERS:-16}}"
NATIVE_GATEWAY_PID=""
NATIVE_GATEWAY_URL=""

# The reasonix flavor is the only flavor. All invocation names run reasonix.
# Export both names: hooks/gateway read CLAUDE_REASONIX_FLAVOR first, CLAUDE_CODEX_
# FLAVOR as the back-compat fallback for an in-flight session.
CLAUDE_REASONIX_FLAVOR="reasonix"
CLAUDE_CODEX_FLAVOR="reasonix"
export CLAUDE_REASONIX_FLAVOR CLAUDE_CODEX_FLAVOR

if [[ "$CLAUDE_REASONIX_FLAVOR" == "reasonix" ]]; then
  : "${CLAUDE_CODEX_SUBAGENT_MODEL:=${CLAUDE_REASONIX_SUBAGENT_MODEL:-claude-reasonix-flash}}"
  : "${ANTHROPIC_CUSTOM_MODEL_OPTION:=claude-reasonix-flash}"
  # UltraCode / Dynamic Workflow defaults to NATIVE mode in reasonix flavor: each
  # agent() lane keeps its reasonix-*/deepseek-* agentType (a native Claude Code
  # subagent type) which gives the parallel phase fan-out (Foundation/CodeReview/Verify)
  # instead of the serial single-MCP-worker behaviour of "fleet" mode.
  # native_subagents=1 lets only-reasonix-fleet.py whitelist those native lanes through.
  # Both are required for fan-out; without them the workflow falls back to one-MCP-lane-at-a-time.
  : "${CLAUDE_CODEX_WORKFLOW_MODE:=${CLAUDE_REASONIX_WORKFLOW_MODE:-native}}"
  : "${CLAUDE_CODEX_NATIVE_SUBAGENTS:=${CLAUDE_REASONIX_NATIVE_SUBAGENTS:-1}}"
  export CLAUDE_CODEX_SUBAGENT_MODEL ANTHROPIC_CUSTOM_MODEL_OPTION
  export CLAUDE_CODEX_WORKFLOW_MODE CLAUDE_CODEX_NATIVE_SUBAGENTS
  # The gateway is spawned with a stripped PATH that often lacks the fnm shim dir
  # holding `reasonix` AND `node` (reasonix is a Node CLI — it needs node on PATH
  # to run at all). Resolve them here, while the launcher's PATH is still complete,
  # export REASONIX_BIN (absolute) and prepend the bin dir so the child gateway can
  # actually invoke reasonix. Without this the lane fails with "Not logged in /
  # please run /login" and returns a synthetic 0-token result.
  if [[ -z "${REASONIX_BIN:-}" ]]; then
    _rx_bin="$(command -v reasonix 2>/dev/null || true)"
    if [[ -n "$_rx_bin" ]]; then
      export REASONIX_BIN="$_rx_bin"
      _rx_dir="$(dirname "$_rx_bin")"
      case ":$PATH:" in
        *":$_rx_dir:"*) ;;
        *) export PATH="$_rx_dir:$PATH" ;;
      esac
    fi
  fi
  # Session isolation for fan-out cache: stock reasonix acp names its persisted
  # session by a MINUTE-granular timestamp and RESUMES any same-name session, so
  # concurrent lanes inherit each other's history (measured: in_tok inflates
  # ~+10829 tok/lane, cache swings 60-94%). Run each acp lane with an ephemeral
  # (non-persisted) session so lanes are fully isolated. Honored by the one-line
  # reasonix dist patch (REASONIX_ACP_EPHEMERAL_SESSION). The gateway also sets
  # this on the child env; exporting here covers any direct reasonix spawn too.
  : "${REASONIX_ACP_EPHEMERAL_SESSION:=1}"
  export REASONIX_ACP_EPHEMERAL_SESSION
fi

usage() {
  cat <<'EOF'
Usage:
  claude-reasonix on [concurrency]   Enable Claude -> Reasonix fleet mode
  claude-reasonix off                Disable fleet mode
  claude-reasonix status             Show current mode and default concurrency
  claude-reasonix workers <count>    Set default Reasonix task concurrency
  claude-reasonix task <prompt>      Run one Claude task through Reasonix fleet, then auto-disable
  claude-reasonix run [claude args]  Start Claude in Reasonix Fleet mode
  claude-reasonix [claude args]      Same as run: always Reasonix Fleet mode
  claude-reasonix plain [args]       Start raw Claude without Reasonix Fleet
  claude-reasonix doctor             Validate local bridge files and commands

Environment overrides:
  CLAUDE_REASONIX_FLEET_DEFAULT_WORKERS=16
  CLAUDE_REASONIX_NATIVE_SUBAGENTS=0
  CLAUDE_REASONIX_NATIVE_SUBAGENTS=1 # experimental native gateway mode
  CLAUDE_REASONIX_ANTHROPIC_API_KEY=... # preferred for router main Anthropic provider

The worker count is dynamic. This launcher starts one Reasonix Fleet MCP server,
not N static Reasonix servers. Claude can ask that server to run any number of
Reasonix tasks, with this value used only as the default concurrency.
EOF
}

ensure_dirs() {
  mkdir -p "$STATE_DIR" "$RUNTIME_DIR"
}

# bridge-settings.json is a portable template: the hook commands carry the
# __INSTALL_HOME__ placeholder so the repo holds no machine path. Render a runtime
# copy with the real INSTALL_HOME substituted and hand THAT to `claude --settings`.
render_settings() {
  ensure_dirs
  python3 - "$SETTINGS_FILE" "$INSTALL_HOME" "$RENDERED_SETTINGS" <<'PY'
import sys
src, install_home, dst = sys.argv[1:4]
with open(src, "r", encoding="utf-8") as fh:
    text = fh.read()
text = text.replace("__INSTALL_HOME__", install_home)
with open(dst, "w", encoding="utf-8") as fh:
    fh.write(text)
PY
}

normalize_workers() {
  local value="${1:-}"
  [[ "$value" =~ ^[0-9]+$ ]] || {
    echo "workers must be a number" >&2
    exit 2
  }
  (( value >= 1 )) || {
    echo "workers must be at least 1" >&2
    exit 2
  }
  printf '%s\n' "$value"
}

current_workers() {
  if [[ -f "$WORKERS_FILE" ]]; then
    normalize_workers "$(tr -d '[:space:]' < "$WORKERS_FILE")"
  else
    normalize_workers "$DEFAULT_WORKERS"
  fi
}

native_subagents_enabled() {
  case "${CLAUDE_REASONIX_NATIVE_SUBAGENTS:-${CLAUDE_CODEX_NATIVE_SUBAGENTS:-0}}" in
    0|false|FALSE|off|OFF|no|NO) return 1 ;;
    *) return 0 ;;
  esac
}

set_workers() {
  ensure_dirs
  normalize_workers "$1" > "$WORKERS_FILE"
}

is_enabled() {
  [[ -f "$ENABLED_FILE" ]]
}

generate_config() {
  ensure_dirs
  local workers
  workers="$(current_workers)"
  python3 - "$MCP_FILE" "$workers" "$REASONIX_BIN" "$MCP_SERVER_FILE" "$RUNTIME_DIR" <<'PY'
import json
import os
import sys

path = sys.argv[1]
default_concurrency = int(sys.argv[2])
reasonix_bin = sys.argv[3]
mcp_server = sys.argv[4]
runtime_dir = sys.argv[5]

model = os.getenv("REASONIX_FLEET_MODEL", "gpt-5.4")
reasoning = os.getenv("REASONIX_FLEET_REASONING", "xhigh")
service_tier = os.getenv("REASONIX_FLEET_SERVICE_TIER", "fast")
web_search = os.getenv("REASONIX_FLEET_WEB_SEARCH", "live")
sandbox = os.getenv("REASONIX_FLEET_SANDBOX", "workspace-write")
approval = os.getenv("REASONIX_FLEET_APPROVAL", "never")

servers = {
    "reasonix_fleet": {
        "command": "/usr/bin/env",
        "args": ["python3", mcp_server],
        "env": {
            "REASONIX_BIN": reasonix_bin,
            "REASONIX_FLEET_DEFAULT_CONCURRENCY": str(default_concurrency),
            "REASONIX_FLEET_MODEL": model,
            "REASONIX_FLEET_REASONING": reasoning,
            "REASONIX_FLEET_SERVICE_TIER": service_tier,
            "REASONIX_FLEET_WEB_SEARCH": web_search,
            "REASONIX_FLEET_SANDBOX": sandbox,
            "REASONIX_FLEET_APPROVAL": approval,
            "REASONIX_FLEET_LOG_DIR": os.path.join(runtime_dir, "logs"),
            # Flavor + reasonix wiring so the MCP worker runs Reasonix via acp
            # in a claude-reasonix session. REASONIX_BIN must be absolute (the MCP
            # is spawned with a stripped PATH that lacks the fnm shim dir).
            "CLAUDE_CODEX_FLAVOR": os.getenv("CLAUDE_REASONIX_FLAVOR", os.getenv("CLAUDE_CODEX_FLAVOR", "reasonix")),
            "REASONIX_BIN": os.getenv("REASONIX_BIN", "reasonix"),
            "CLAUDE_CODEX_REASONIX_MODEL": os.getenv("CLAUDE_REASONIX_REASONIX_MODEL", os.getenv("CLAUDE_CODEX_REASONIX_MODEL", "deepseek-v4-flash")),
            "CLAUDE_CODEX_REASONIX_COST_LEDGER": os.path.join(runtime_dir, "reasonix-cost.jsonl"),
        },
    }
}

with open(path, "w", encoding="utf-8") as fh:
    json.dump({"mcpServers": servers}, fh, indent=2)
    fh.write("\n")
PY
  printf '%s\n' "$MCP_FILE"
}

generate_agents() {
  ensure_dirs
  python3 - "$AGENTS_FILE" <<'PY'
import json
import os
import sys

path = sys.argv[1]
reasonix_model = os.getenv("CLAUDE_REASONIX_NATIVE_REASONIX_MODEL", os.getenv("CLAUDE_CODEX_NATIVE_REASONIX_MODEL", "claude-reasonix-flash"))
tools = [
    item.strip()
    for item in os.getenv("CLAUDE_REASONIX_NATIVE_AGENT_TOOLS", os.getenv("CLAUDE_CODEX_NATIVE_AGENT_TOOLS", "Read,Grep,Glob,Bash,Edit,Write,MultiEdit")).split(",")
    if item.strip()
]

def agent(description, prompt, model):
    return {
        "description": description,
        "prompt": prompt,
        "tools": tools,
        "disallowedTools": ["Agent", "Task"],
        "model": model,
        "effort": "xhigh",
        "permissionMode": "acceptEdits",
    }

# PREFIX-CACHE STABILITY: every agent type MUST share a byte-identical system
# prompt so all lanes in a fan-out belong to ONE DeepSeek prefix family. The old
# per-role suffix ("Focus especially on security…") sat ~char 355 — inside the
# first 4KB — so each agent type became its own prefix family (measured: 5 families
# on a real run → weighted cache 89.76%). Role focus now lives in this SHARED base
# (uniform for all) instead of a per-agent suffix; lane-specific intent already
# arrives via the task tail + the distinct `description` Claude routes on. The
# `description` differs per agent (routing only — NOT sent to the model), so
# fan-out behaviour is unchanged; only the cached prefix is unified.
reasonix_prompt = (
    "You are a native Claude Code subagent backed by Reasonix (DeepSeek) through "
    "the local claude-reasonix gateway. Do the worker-lane task directly with the "
    "available repository tools. Use fast, decisive coding-agent behavior, preserve "
    "user changes, and return concise evidence-backed results. Match your focus to "
    "the lane: for security lanes weigh exploitability and remediation; for review "
    "lanes weigh bugs, regressions, and missing tests; for verification lanes run or "
    "design targeted checks and report exact commands and outcomes; for deep/"
    "architecture lanes weigh system boundaries, data/API flows, and operational risk."
)

agents = {
    "reasonix-worker": agent(
        "General Reasonix worker for implementation, file analysis, repo search, and focused worker lanes.",
        reasonix_prompt,
        reasonix_model,
    ),
    "reasonix-security": agent(
        "Reasonix security review worker. Use for security, auth, secrets, permissions, injection, and abuse-case lanes.",
        reasonix_prompt,
        reasonix_model,
    ),
    "reasonix-reviewer": agent(
        "Reasonix code-review worker. Use for CodeReview lanes, regression checks, architecture/infra review, and independent diff review.",
        reasonix_prompt,
        reasonix_model,
    ),
    "reasonix-verify": agent(
        "Reasonix verification worker. Use for test, verify, reproduction, and acceptance-criteria lanes.",
        reasonix_prompt,
        reasonix_model,
    ),
}

with open(path, "w", encoding="utf-8") as fh:
    json.dump(agents, fh, indent=2)
    fh.write("\n")
PY
  printf '%s\n' "$AGENTS_FILE"
}

agents_json() {
  generate_agents >/dev/null
  python3 - "$AGENTS_FILE" <<'PY'
import json
import sys

with open(sys.argv[1], "r", encoding="utf-8") as fh:
    print(json.dumps(json.load(fh), separators=(",", ":")))
PY
}

start_native_gateway() {
  ensure_dirs
  [[ -f "$GATEWAY_FILE" ]] || {
    echo "missing native gateway: $GATEWAY_FILE" >&2
    exit 1
  }

  local host="${CLAUDE_REASONIX_GATEWAY_HOST:-${CLAUDE_CODEX_GATEWAY_HOST:-127.0.0.1}}"
  local port="${CLAUDE_REASONIX_GATEWAY_PORT:-${CLAUDE_CODEX_GATEWAY_PORT:-0}}"
  local port_file="$RUNTIME_DIR/gateway.$$.port"
  local log_file="$RUNTIME_DIR/gateway.log"
  local upstream_base="${CLAUDE_REASONIX_GATEWAY_ANTHROPIC_BASE_URL:-${CLAUDE_CODEX_GATEWAY_ANTHROPIC_BASE_URL:-${ANTHROPIC_BASE_URL:-https://api.anthropic.com}}}"
  local gateway_concurrency="${CLAUDE_REASONIX_GATEWAY_CONCURRENCY:-${CLAUDE_CODEX_GATEWAY_CODEX_CONCURRENCY:-$(current_workers)}}"
  rm -f "$port_file"

  CLAUDE_CODEX_GATEWAY_ANTHROPIC_BASE_URL="$upstream_base" \
    CLAUDE_CODEX_GATEWAY_CODEX_CONCURRENCY="$gateway_concurrency" \
    python3 "$GATEWAY_FILE" --host "$host" --port "$port" --port-file "$port_file" >>"$log_file" 2>&1 &
  NATIVE_GATEWAY_PID="$!"

  local i
  for i in {1..100}; do
    if [[ -s "$port_file" ]]; then
      local actual_port
      actual_port="$(tr -d '[:space:]' < "$port_file")"
      NATIVE_GATEWAY_URL="http://$host:$actual_port"
      rm -f "$port_file"
      return 0
    fi
    if ! kill -0 "$NATIVE_GATEWAY_PID" 2>/dev/null; then
      echo "native gateway exited before startup; see $log_file" >&2
      exit 1
    fi
    sleep 0.05
  done

  echo "native gateway did not start; see $log_file" >&2
  kill "$NATIVE_GATEWAY_PID" 2>/dev/null || true
  exit 1
}

stop_native_gateway() {
  if [[ -n "${NATIVE_GATEWAY_PID:-}" ]] && kill -0 "$NATIVE_GATEWAY_PID" 2>/dev/null; then
    kill "$NATIVE_GATEWAY_PID" 2>/dev/null || true
    wait "$NATIVE_GATEWAY_PID" 2>/dev/null || true
  fi
  NATIVE_GATEWAY_PID=""
  NATIVE_GATEWAY_URL=""
}

find_free_port() {
  python3 - <<'PY'
import socket

with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
    sock.bind(("127.0.0.1", 0))
    print(sock.getsockname()[1])
PY
}

allowed_tools_csv() {
  printf '%s\n' "mcp__reasonix_fleet__*"
}

bridge_prompt() {
  local workers
  workers="$(current_workers)"
  printf 'This Claude Code session is running Reasonix Fleet dynamic mode. Use the reasonix_fleet MCP server to dispatch any number of Reasonix CLI subagents. Default concurrent Reasonix tasks: %s.\n\n' "$workers"
  cat "$PROMPT_FILE"
}

run_claude_with_fleet() {
  [[ -f "$SETTINGS_FILE" ]] || {
    echo "missing bridge settings: $SETTINGS_FILE" >&2
    exit 1
  }
  [[ -f "$PROMPT_FILE" ]] || {
    echo "missing bridge prompt: $PROMPT_FILE" >&2
    exit 1
  }
  [[ -f "$MCP_SERVER_FILE" ]] || {
    echo "missing Reasonix Fleet MCP server: $MCP_SERVER_FILE" >&2
    exit 1
  }

  generate_config >/dev/null
  render_settings
  local prompt
  prompt="$(bridge_prompt)"
  local base_args=(
    --mcp-config "$MCP_FILE"
    --settings "$RENDERED_SETTINGS"
    --append-system-prompt "$prompt"
  )

  if native_subagents_enabled; then
    local agent_defs
    agent_defs="$(agents_json)"
    local forced_subagent_model="${CLAUDE_REASONIX_SUBAGENT_MODEL:-${CLAUDE_CODEX_SUBAGENT_MODEL:-${CLAUDE_CODEX_NATIVE_REASONIX_MODEL:-claude-reasonix-flash}}}"
    start_native_gateway
    set +e
    CLAUDE_CODEX_NATIVE_SUBAGENTS=1 \
      CLAUDE_CODEX_WORKFLOW_MODE=native \
      CLAUDE_CODE_SUBAGENT_MODEL="$forced_subagent_model" \
      ANTHROPIC_BASE_URL="$NATIVE_GATEWAY_URL" \
      CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY="${CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY:-1}" \
      ANTHROPIC_CUSTOM_MODEL_OPTION="${ANTHROPIC_CUSTOM_MODEL_OPTION:-claude-reasonix-flash}" \
      ANTHROPIC_CUSTOM_MODEL_OPTION_NAME="${ANTHROPIC_CUSTOM_MODEL_OPTION_NAME:-claude-reasonix-flash}" \
      ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION="${ANTHROPIC_CUSTOM_MODEL_OPTION_DESCRIPTION:-Reasonix-backed native Claude Code subagent model}" \
      ANTHROPIC_CUSTOM_MODEL_OPTION_SUPPORTED_CAPABILITIES="${ANTHROPIC_CUSTOM_MODEL_OPTION_SUPPORTED_CAPABILITIES:-effort,xhigh_effort,thinking,interleaved_thinking}" \
      "$CLAUDE_BIN" \
        "${base_args[@]}" \
        --agents "$agent_defs" \
        "$@"
    local code=$?
    set -e
    stop_native_gateway
    return "$code"
  fi

  CLAUDE_CODEX_NATIVE_SUBAGENTS=0 \
    CLAUDE_CODEX_WORKFLOW_MODE=fleet \
    "$CLAUDE_BIN" \
    "${base_args[@]}" \
    --disallowedTools "Agent,Task" \
    "$@"
}

run_claude() {
  run_claude_with_fleet "$@"
}

run_plain_claude() {
  exec "$CLAUDE_BIN" "$@"
}

run_task() {
  ensure_dirs
  [[ "$#" -gt 0 ]] || {
    echo "usage: claude-reasonix task <prompt or claude -p args>" >&2
    exit 2
  }
  rm -f "$ENABLED_FILE"
  set +e
  run_claude_with_fleet -p "$@"
  local code=$?
  set -e
  rm -f "$ENABLED_FILE"
  return "$code"
}

process_list() {
  if [[ -n "${CLAUDE_REASONIX_PS_FIXTURE:-${CLAUDE_CODEX_PS_FIXTURE:-}}" ]]; then
    cat "${CLAUDE_REASONIX_PS_FIXTURE:-${CLAUDE_CODEX_PS_FIXTURE:-}}"
  else
    ps -axo pid=,command=
  fi
}

report_active_sessions() {
  python3 - "$MCP_FILE" "${CLAUDE_REASONIX_MODEL:-${CLAUDE_CODEX_CODEX_MODEL:-${REASONIX_FLEET_MODEL:-gpt-5.4}}}" "$(current_workers)" "${CLAUDE_REASONIX_PS_FIXTURE:-${CLAUDE_CODEX_PS_FIXTURE:-}}" <<'PY'
import re
import subprocess
import sys

mcp_file, expected_model, expected_concurrency, fixture = sys.argv[1:]
expected_lower = expected_model.lower()
sessions = []

if fixture:
    with open(fixture, "r", encoding="utf-8", errors="replace") as fh:
        lines = fh.readlines()
else:
    result = subprocess.run(
        ["ps", "-axo", "pid=,command="],
        check=False,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
    )
    lines = result.stdout.splitlines()

for raw_line in lines:
    line = raw_line.strip()
    if not line:
        continue
    parts = line.split(None, 1)
    if len(parts) != 2 or not parts[0].isdigit():
        continue
    pid, command = parts
    if "--mcp-config" not in command or mcp_file not in command:
        continue
    if "claude" not in command:
        continue

    lowered = command.lower()
    if "--agents" in command or "router mode" in lowered or "ccr" in lowered:
        mode = "router"
    elif "--disallowedTools" in command or "--disallowedtools" in lowered:
        mode = "fleet"
    else:
        mode = "unknown"

    fields = [f"pid={pid}", f"mode={mode}"]
    restart_required = False
    if "gpt-5.5" in lowered:
        fields.append("stale_model=gpt-5.5")
        fields.append("restart required")
        restart_required = True
    elif expected_lower in lowered:
        fields.append(f"model={expected_model}")
    else:
        fields.append("model=unknown")

    concurrency_match = (
        re.search(r"default concurrency (\d+)", lowered)
        or re.search(r"default concurrent reasonix tasks: (\d+)", lowered)
    )
    if concurrency_match:
        active_concurrency = concurrency_match.group(1)
        if active_concurrency != expected_concurrency:
            fields.append(f"stale_concurrency={active_concurrency}")
            fields.append("restart required")
            restart_required = True
        else:
            fields.append(f"concurrency={active_concurrency}")
    sessions.append(("  " + " ".join(fields), restart_required))

if sessions:
    print("active claude-reasonix sessions:")
    for text, _ in sessions:
        print(text)
    if any(restart for _, restart in sessions):
        print("warning: restart required for stale claude-reasonix sessions to use the current model/config")
PY
}

status() {
  ensure_dirs
  if is_enabled; then
    echo "reasonix fleet: enabled"
  else
  echo "reasonix fleet: disabled"
  fi
  echo "default concurrency: $(current_workers)"
  echo "gateway concurrency: ${CLAUDE_REASONIX_GATEWAY_CONCURRENCY:-${CLAUDE_CODEX_GATEWAY_CODEX_CONCURRENCY:-$(current_workers)}}"
  echo "fleet home: $FLEET_HOME"
  echo "install home: $INSTALL_HOME"
  report_active_sessions
}

doctor() {
  local ok=0
  [[ -f "$SETTINGS_FILE" ]] || { echo "missing $SETTINGS_FILE" >&2; ok=1; }
  [[ -f "$PROMPT_FILE" ]] || { echo "missing $PROMPT_FILE" >&2; ok=1; }
  [[ -f "$INSTALL_HOME/hooks/only-reasonix-fleet.py" ]] || { echo "missing guard hook" >&2; ok=1; }
  [[ -f "$INSTALL_HOME/hooks/reasonix-workflow.py" ]] || { echo "missing workflow hook" >&2; ok=1; }
  [[ -f "$MCP_SERVER_FILE" ]] || { echo "missing $MCP_SERVER_FILE" >&2; ok=1; }
  [[ -f "$GATEWAY_FILE" ]] || { echo "missing $GATEWAY_FILE" >&2; ok=1; }
  python3 -m json.tool "$SETTINGS_FILE" >/dev/null || ok=1
  generate_config >/dev/null || ok=1
  generate_agents >/dev/null || ok=1
  python3 -m json.tool "$MCP_FILE" >/dev/null || ok=1
  python3 -m json.tool "$AGENTS_FILE" >/dev/null || ok=1
  python3 -m py_compile "$MCP_SERVER_FILE" || ok=1
  python3 -m py_compile "$GATEWAY_FILE" || ok=1
  "$CLAUDE_BIN" --version >/dev/null || { echo "claude command failed" >&2; ok=1; }
  command -v reasonix >/dev/null || { echo "reasonix command not found" >&2; ok=1; }
  report_active_sessions
  if (( ok == 0 )); then
    echo "reasonix fleet doctor: ok"
  fi
  exit "$ok"
}

main() {
  local command="${1:-run}"
  case "$command" in
    on)
      shift
      ensure_dirs
      if [[ "${1:-}" != "" ]]; then
        set_workers "$1"
      elif [[ ! -f "$WORKERS_FILE" ]]; then
        set_workers "$DEFAULT_WORKERS"
      fi
      touch "$ENABLED_FILE"
      generate_config >/dev/null
      status
      ;;
    off)
      shift || true
      ensure_dirs
      rm -f "$ENABLED_FILE"
      status
      ;;
    status)
      shift || true
      status
      ;;
    workers)
      shift
      [[ "${1:-}" != "" ]] || {
        echo "usage: claude-reasonix workers <count>" >&2
        exit 2
      }
      set_workers "$1"
      generate_config >/dev/null
      status
      ;;
    task|once)
      shift || true
      run_task "$@"
      ;;
    generate-config)
      shift || true
      generate_config
      ;;
    generate-agents)
      shift || true
      generate_agents
      ;;
    doctor)
      shift || true
      doctor
      ;;
    cost)
      shift || true
      LEDGER="${CLAUDE_REASONIX_REASONIX_COST_LEDGER:-${CLAUDE_CODEX_REASONIX_COST_LEDGER:-$RUNTIME_DIR/reasonix-cost.jsonl}}"
      python3 - "$GATEWAY_FILE" "$LEDGER" <<'PY'
import importlib.util, sys
spec = importlib.util.spec_from_file_location("g", sys.argv[1])
g = importlib.util.module_from_spec(spec); spec.loader.exec_module(g)
s = g.summarize_reasonix_cost(sys.argv[2])
if s["lanes"] == 0:
    print("Reasonix cost: no lanes recorded yet (ledger: %s)" % sys.argv[2])
else:
    print("Reasonix cost (ledger: %s)" % sys.argv[2])
    print("  lanes: %d | total: $%.4f | avg/lane: $%.6f" % (s["lanes"], s["total_usd"], s["avg_per_lane_usd"]))
    print("  cache: %.1f%% avg | tokens: %d in / %d out" % (s["avg_cache_pct"], s["input_tokens"], s["output_tokens"]))
    if s["claude_equiv_usd"] > 0:
        print("  vs Claude: would be $%.4f -> saved ~$%.4f (%.1f%%)" % (s["claude_equiv_usd"], s["saved_usd"], s["saved_pct"]))
PY
      ;;
    run)
      shift || true
      run_claude "$@"
      ;;
    plain|claude)
      shift || true
      run_plain_claude "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      run_claude "$@"
      ;;
  esac
}

main "$@"
